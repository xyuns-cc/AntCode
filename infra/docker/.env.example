# =====================================================
# AntCode Docker 环境变量配置示例
# =====================================================
# 复制此文件到 .env 并修改配置
# cp .env.example .env
#
# 重要：所有密码字段为必填，无默认值。
# =====================================================

# ================== 服务端口 ==================
WEB_API_PORT=8000
GATEWAY_GRPC_PORT=50051
FRONTEND_PORT=3000

# ================== MySQL 配置（必填）==================
MYSQL_ROOT_PASSWORD=           # 必填：MySQL root 密码
MYSQL_DATABASE=antcode
MYSQL_USER=antcode
MYSQL_PASSWORD=                # 必填：MySQL 应用用户密码

# ================== Redis 配置（必填）==================
REDIS_PASSWORD=                # 必填：Redis 密码

# ================== MinIO 配置（必填）==================
MINIO_ROOT_USER=               # 必填：MinIO 管理员用户名
MINIO_ROOT_PASSWORD=           # 必填：MinIO 管理员密码

# ================== Master 配置 ==================
MASTER_ID=master-1

# ================== Worker 配置 ==================
# 模式: direct (内网直连 Redis) 或 gateway (公网走 gRPC)
WORKER_TRANSPORT_MODE=direct
WORKER_NAME=worker-1

# ================== 安全配置（必填）==================
# 加密密钥（独立于 JWT，用于 SecretBox 加密）
ENCRYPTION_KEY=                # 必填：任意随机字符串

# ================== 日志配置 ==================
LOG_LEVEL=INFO
LOG_TO_FILE=true
